# Credentials are interpolated into src/test/resources/config/qa.properties as
# ${TRUPEER_EMAIL} / ${TRUPEER_PASSWORD}. Export them before running the tests.

TRUPEER_EMAIL=you@example.com
TRUPEER_PASSWORD=your-password

# Optional runtime overrides are passed on the command line, e.g.:
#   mvn test -Dheadless=true
#   mvn test -Denvironment=qa
#   mvn test "-Dcucumber.filter.tags=@login"
